{
  "name": "journey-jotter",
  "description": "A journaling app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared/packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev-app": "turbo run dev --filter=@journey-jotter/journey-jotter",
    "dev-admin-dashboard": "turbo run dev --filter=@journey-jotter/admin-dashboard",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "install:journal-creator": "npm install --workspace=@journey-jotter/journal-creator-v2",
    "build:journal-creator": "npm run build --workspace=@journey-jotter/journal-creator-v2",
    "db:generate": "npm run db:generate --workspace=@journey-jotter/db",
    "db:migrate": "npm run db:migrate --workspace=@journey-jotter/db",
    "db:seed": "npm run db:seed --workspace=@journey-jotter/db",
    "db:push": "npm run db:push --workspace=@journey-jotter/db",
    "db:seed-questions": "npm run db:seed-questions --workspace=@journey-jotter/db"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.9",
    "@types/node-geocoder": "^4.2.6",
    "drizzle-kit": "^0.24.2",
    "prettier": "3.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "turbo": "^1.10.0"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.12",
    "@heroicons/react": "^2.1.5",
    "@mem0/vercel-ai-provider": "latest",
    "@neondatabase/serverless": "^0.9.5",
    "@opentelemetry/api-logs": "^0.56.0",
    "@opentelemetry/instrumentation": "^0.56.0",
    "@opentelemetry/sdk-logs": "^0.56.0",
    "@react-google-maps/api": "^2.19.3",
    "@tanstack/react-query": "^5.56.2",
    "@tiptap/extension-image": "^2.7.1",
    "@tiptap/extension-link": "^2.7.1",
    "@tiptap/extension-table": "^2.7.1",
    "@tiptap/extension-table-cell": "^2.7.1",
    "@tiptap/extension-table-header": "^2.7.1",
    "@tiptap/extension-table-row": "^2.7.1",
    "@tiptap/pm": "^2.7.1",
    "@tiptap/react": "^2.7.1",
    "@tiptap/starter-kit": "^2.7.1",
    "@vercel/otel": "latest",
    "ai": "latest",
    "cookies-next": "^4.3.0",
    "dexie": "^4.0.11",
    "dexie-cloud-addon": "^4.0.11",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.24.2",
    "drizzle-orm": "^0.33.0",
    "embla-carousel-autoplay": "^8.5.1",
    "framer-motion": "^11.9.0",
    "langfuse-vercel": "^3.31.1",
    "lodash": "^4.17.21",
    "lottie-react": "^2.4.0",
    "next": "15.2.8",
    "node-geocoder": "^4.4.0",
    "or": "^0.2.0",
    "pg": "^8.13.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.3.0",
    "react-markdown": "^9.0.1",
    "tailwindcss-displaymodes": "^1.0.8"
  },
  "overrides": {
    "@types/react": "18.2.73",
    "@ai-sdk/provider-utils": "latest"
  }
}
